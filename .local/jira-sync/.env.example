JIRA_URL=https://saritasa.atlassian.net
JIRA_EMAIL=you@saritasa.com
JIRA_API_TOKEN=your_api_token_here
JIRA_PROJECT_KEY=PROJ-KEY

# Default output goes to sibling dev folder when jira-sync sits next to dev
DOWNLOAD_PATH=../../dev/tasks

# GitHub repo for fetching PR data (owner/repo).
# If not set, PR fetching is skipped even when --with-prs is used.
GITHUB_REPO=saritasa-nest/rma-mobile
